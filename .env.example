# Telegram Bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=0

# YooKassa (https://yookassa.ru → Настройки → Ключи API)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_RETURN_URL=https://t.me/Pesdata_bot
YOOKASSA_WEBHOOK_PATH=/yookassa/webhook

# PostgreSQL для Vercel (Neon/Supabase/Vercel Postgres)
# postgres://user:pass@host/db → автоматически конвертируется
DATABASE_URL=postgresql://user:password@host:5432/pesdata

# Admin Panel
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_long_secure_password_here
ADMIN_SECRET_KEY=random-64-char-secret-for-sessions

# Local only
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8000
LOG_LEVEL=INFO
